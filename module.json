{
    "id": "exalted-calendar",
    "title": "Easy Exalted Timekeeping",
    "version": "vDev",
    "compatibility": {
        "minimum": "13",
        "verified": "13"
    },
    "description": "Easy Exalted Timekeeping implements simplistic handling exalted seasons, months, moon phases, days and hours. Forked from jd-easytimekeeping, thanks for boilerplate.",
    "authors": [
        {
          "name": "Troi",
          "flags": {}
        }
    ],
    "esmodules": [
        "src/initialisation.mjs"
    ],
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json",
            "flags": {}
        },
        {
            "lang": "fr",
            "name": "Français",
            "path": "lang/fr.json",
            "flags": {}
        },
        {
            "lang": "it",
            "name": "Italiano",
            "path": "lang/it.json",
            "flags": {}
        }
    ],
    "styles": [
        "styles/easy-timekeeping.css"
    ],
    "packs": [
        {
            "name": "macros",
            "label": "Example Macros",
            "path": "packs/macros",
            "type": "Macro",
            "ownership": {
                "PLAYER": "OBSERVER",
                "ASSISTANT": "OWNER"
            }
        }
    ],
    "socket": true,
    "url": "https://github.com/BlackCornerStone/exalted-calendar",
    "manifest": "https://github.com/BlackCornerStone/exalted-calendar/releases/latest/download/module.json",
    "download": "https://github.com/BlackCornerStone/exalted-calendar/releases/download/vX.Y.Z/module.zip"
}